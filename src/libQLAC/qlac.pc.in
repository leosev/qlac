prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: QLAC
Description: Quick Lossless Audio Codec Library
Version: @VERSION@
Libs: -L${libdir} -lQLAC
Libs.private: -lm @QLAC_STATIC_LIBS@
Cflags: -I${includedir}
